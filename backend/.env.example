# ─────────────────────────────────────────────────────────────────
#  HRReflect Backend — Environment Variables
#  cp .env.example .env   then fill in your values
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB ───────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/hrreflect
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/hrreflect
MONGODB_URI=mongodb://localhost:27017/hrreflect

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=hrreflect_super_secret_jwt_key_change_this_in_production_min32chars
JWT_EXPIRES_IN=7d

# ── Admin 1 — Superadmin ──────────────────────────────────────────
ADMIN_NAME=HRReflect Admin
ADMIN_EMAIL=info@hrreflect.com
ADMIN_PASSWORD=hrreflect@admin2024

# ── Admin 2 — Lekkala Bhaskar ─────────────────────────────────────
ADMIN2_EMAIL=bhaskar@hrreflect.com
ADMIN2_PASSWORD=Bhaskar@HRR2024

# ── Email / SMTP (optional — leave blank to skip emails) ──────────
# Gmail: Google Account → Security → 2-Step → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=HRReflect <info@hrreflect.com>
ADMIN_NOTIFY_EMAIL=info@hrreflect.com

# ── CORS — must match your live domain exactly ────────────────────
FRONTEND_URL=https://hrreflect.com

# ── File Upload ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
