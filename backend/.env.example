# ─── DATABASE ──────────────────────────────────────────────
# Get this from MongoDB Atlas: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/hrreflect

# ─── AUTH ──────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=hrreflect-super-secret-jwt-key-change-this

# ─── EMAIL (Nodemailer) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@hrreflect.com
# Use Gmail App Password (not your login password)
# Get it at: myaccount.google.com > Security > App Passwords
SMTP_PASS=your-gmail-app-password
ADMIN_EMAIL=info@hrreflect.com

# ─── APP ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://hrreflect.com

# ─── ADMIN ACCOUNTS (used by seed script) ─────────────────
ADMIN_NAME=HRReflect Admin
ADMIN_EMAIL=info@hrreflect.com
ADMIN_PASSWORD=hrreflect@admin2024

ADMIN2_EMAIL=bhaskar@hrreflect.com
ADMIN2_PASSWORD=Bhaskar@HRR2024
