# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/hrreflect

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ─── Admin Credentials (used by seed script to create default admin) ──────────
ADMIN_EMAIL=info@hrreflect.com
ADMIN_PASSWORD=hrreflect@admin2024
ADMIN_NAME=HRReflect Admin

# ─── Email (Nodemailer / SMTP) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=HRReflect <info@hrreflect.com>

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── File Upload ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads
